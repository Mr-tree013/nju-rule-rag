APP_TITLE=NJU Rule RAG

# LLM API — 推荐本地 Qwen3-8B（Ollama），也可以接云端 API
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3:8b-nothink

# LLM 回退 — 本地模型故障时自动切到云端（可选）
ENABLE_LLM_FALLBACK=false
FALLBACK_LLM_API_KEY=your-deepseek-key-here
FALLBACK_LLM_BASE_URL=https://api.deepseek.com
FALLBACK_LLM_MODEL=deepseek-chat

# Embedding API (can share keys with LLM if same provider)
EMBEDDING_API_KEY=your-api-key-here
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

# Data paths
DATA_DIR=data
CHUNKS_FILE=data/chunks/chunks.jsonl
INDEX_DIR=data/index

# Retrieval
BM25_TOP_K=10
VECTOR_TOP_K=10
HYBRID_TOP_K=5
MIN_RELIABLE_SCORE=0.2
HIGH_RISK_MIN_SCORE=0.25

# Reranker (task 3.1 — two-stage retrieval, default off)
ENABLE_RERANK=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANK_CANDIDATE_K=40
RERANK_TOP_K=12

# Build options
ENABLE_VECTOR=true
LOCAL_EMBEDDING_MODEL=shibing624/text2vec-base-chinese

# QQ Bot (NapCat OneBot v11)
QQ_BOT_SELF_ID=你的QQ号
QQ_BOT_API_BASE_URL=http://127.0.0.1:8000
